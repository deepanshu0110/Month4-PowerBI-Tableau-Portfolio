                  <story-point caption=' Revenue split across regions shows South &amp; West lead — but WHY?' captured-sheet='Revenue by Region &amp; Category' id='1' />
                  <story-point caption='Monthly trend reveals Q2 dip in May — return rates spike simultaneously' captured-sheet='Monthly Revenue Trend with Return Rate' id='2' />
