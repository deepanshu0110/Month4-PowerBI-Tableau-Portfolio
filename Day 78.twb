      <aliases enabled='yes' />
      <column caption='Profit Margin %' datatype='real' name='[Calculation_0905241008996352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Revenue])' />
      </column>
      <column caption='Revenue Band' datatype='string' name='[Calculation_0905241009106945]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Revenue] &gt;= 30000 THEN &apos;High&apos;&#13;&#10;ELSEIF [Revenue] &gt;= 10000 THEN &apos;Mid&apos;&#13;&#10;ELSE &apos;Low&apos; END' />
      </column>
      <column caption='Profit Flag' datatype='string' name='[Calculation_0905241009176578]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF([Profit] &gt; 0, &apos;Profitable&apos;, &apos;Loss&apos;)' />
      </column>
      <column caption='Days Since Order' datatype='integer' name='[Calculation_0905241009467395]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, DATE([OrderDate]), TODAY())' />
      </column>
      <column caption='Region Total Revenue' datatype='integer' name='[Calculation_0905241013915652]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Region] : SUM([Revenue])}' />
      </column>
      <column caption='Revenue % of Grand Total' datatype='real' name='[Calculation_0905241014009861]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / SUM({ FIXED : SUM([Revenue]) })' />
      </column>
      <column caption='Customer Best Order' datatype='integer' name='[Calculation_0905241014267910]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [CustomerID] : MAX([Revenue])}' />
      </column>
      <column caption='Avg Revenue per Customer (by Region)' datatype='real' name='[Calculation_0905241017724935]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [CustomerID] : AVG([Revenue]) }' />
      </column>
      <column caption='Category vs Overall Avg' datatype='real' name='[Calculation_0905241019932680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) - SUM({ EXCLUDE [Category] : AVG([Revenue]) })' />
      </column>
      <column caption='Customer ID' datatype='string' name='[CustomerID]' role='dimension' type='nominal' />
      <column caption='Customer Name' datatype='string' name='[CustomerName]' role='dimension' type='nominal' />
      <column aggregation='None' datatype='integer' name='[Days Since Order (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='1' formula='[Calculation_0905241009467395]' peg='0' size='11.4' />
      </column>
      <column aggregation='Count' caption='Order Date' datatype='date' datatype-customized='true' name='[OrderDate]' role='dimension' type='ordinal' />
