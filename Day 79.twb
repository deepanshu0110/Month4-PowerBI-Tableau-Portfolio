    </action>
    <action caption='Category Highlight' name='[Action2_C4CFBC9FF8AC4D948FF7A97B7597E5DD]'>
      <activation auto-clear='true' type='on-hover' />
      <source type='sheet' worksheet='Category_Breakdown' />
      <command command='tsc:brush'>
