  <actions>
    <action caption='Region Drill-Down' name='[Action1_EF1ACC0D10F242F68E8456D4DCB80120]'>
      <activation auto-clear='true' type='on-select' />
      <source type='sheet' worksheet='Revenue_by_Region' />
      <command command='tsc:tsl-filter'>
        <param name='exclude' value='Revenue_by_Region,Top10_Customers' />
        <param name='special-fields' value='all' />
        <param name='target' value='Dashboard 1' />
