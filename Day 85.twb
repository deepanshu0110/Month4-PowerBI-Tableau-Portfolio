      <aliases enabled='yes' />
      <column caption='Total Revenue' datatype='integer' name='[Calculation_1491762546634752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_1491762546708481]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([OrderID])' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_1491762546974722]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / COUNTD([OrderID])' />
      </column>
      <column caption='Return Rate %' datatype='real' default-format='p0.0%' name='[Calculation_1491762547023875]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Returned]=&apos;Yes&apos; THEN [OrderID] END) / COUNTD([OrderID])' />
      </column>
      <column caption='Revenue per Unit' datatype='real' name='[Calculation_1491762547109892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / SUM([Units])' />
      </column>
      <column caption='North Revenue' datatype='integer' name='[Calculation_1491762547212293]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Region]=&apos;North&apos; THEN [Revenue] END' />
      </column>
      <column caption='Electronics Revenue' datatype='integer' name='[Calculation_1491762547347462]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Category]=&apos;Electronics&apos; THEN [Revenue] END' />
      </column>
      <column caption='High Value Orders' datatype='integer' name='[Calculation_1491762547478535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Revenue]&gt;10000 THEN [OrderID] END)' />
      </column>
      <column caption='Quarter Filter' datatype='string' name='[Calculation_1491762550759433]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;Q&apos; + STR(INT(([MonthNum]-1)/3)+1)' />
      </column>
      <column datatype='string' name='[Category]' role='dimension' type='nominal' />
      <column caption='Month Num' datatype='integer' name='[MonthNum]' role='dimension' type='quantitative' />
      <column caption='Order ID' datatype='string' name='[OrderID]' role='dimension' type='nominal' />
      <column caption='Return Reason' datatype='string' name='[ReturnReason]' role='dimension' type='nominal' />
      <column caption='Unit Price' datatype='integer' name='[UnitPrice]' role='measure' type='quantitative' />
