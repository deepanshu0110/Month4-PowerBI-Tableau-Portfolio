  <worksheets>
    <worksheet name='Monthly Revenue Trend'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontsize='16'>Total revenue peaked in March (₹1.38L), driven by Furniture, then fell 47% in April; June recovered to ₹1.03L – investigate the April demand drop across all categories.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
