      <aliases enabled='yes' />
      <column caption='Profit Margin %' datatype='real' default-format='p0.0%' name='[Calculation_0273297060999168]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Revenue])' />
      </column>
      <column caption='Revenue Band ' datatype='string' name='[Calculation_0273297061105665]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Revenue] &lt; 1000 THEN &apos;Low&apos;&#13;&#10;ELSEIF [Revenue] &lt; 5000 THEN &apos;Medium&apos;&#13;&#10;ELSE &apos;High&apos;&#13;&#10;END' />
      </column>
      <column caption='Delivery Speed' datatype='string' name='[Calculation_0273297061269506]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [DeliveryDays] &lt;= 3 THEN &apos;Express&apos;&#13;&#10;ELSEIF [DeliveryDays] &lt;= 7 THEN &apos;Standard&apos;&#13;&#10;ELSE &apos;Slow&apos;&#13;&#10;END' />
      </column>
      <column caption='Category Avg Margin' datatype='real' name='[Calculation_0273297061478403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Category] : AVG([Profit] / [Revenue]) }' />
      </column>
